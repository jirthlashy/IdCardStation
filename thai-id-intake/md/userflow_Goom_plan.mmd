%% User flow for the goomgumx Thai ID SmartCard reader plan
%% Security-focused version:
%% - Station PC shows only a short scan code/status, not patient data.
%% - Nurse iPad receives full scan data only for its own request/session.
%% - Normal operation: station PC 0 clicks, nurse iPad 1 tap.

flowchart TD
  Start["Patient arrives at A01 with Thai ID card"]
  NurseTap["Nurse taps Scan ID Card on iPad\n1 tap"]
  BackendRequest["Backend creates scan request transaction\nrequestId + nurseId + deviceSessionId + stationId"]
  TurnCode["Generate short turn code\nexample: A7K2Q\nexpires in 60-120 seconds"]
  PrivateSub["Nurse iPad subscribes to private result topic\nscan-result.{deviceSessionId}"]
  PcDisplay["Station PC display shows active turn code only\nnormal operation: 0 PC clicks"]
  Compare{"Does iPad code match station PC code?"}
  WaitTurn["Not this nurse's turn\nwait until matching code appears"]
  Insert["Insert patient's Thai ID card into reader"]
  AgentRead["Local reader-agent reads card automatically\n0 clicks"]
  BindRead["Reader agent attaches active requestId\nto the scan result"]
  KafkaPrivate["Backend/Kafka publishes full scan data\nonly to nurse private topic"]
  Autofill["Nurse iPad receives result\npatient card fields autofill"]
  Done["Patient is active for this nurse/session"]

  WrongCard["Wrong patient appears on nurse iPad"]
  Reject["Nurse taps Wrong Patient / Not Mine"]
  Misrouted["Backend marks scan misrouted\nfull data is not broadcast"]
  Rescan["Correct nurse makes/uses their own scan request\ncard must be rescanned under matching code"]
  Expired["Request expires\nnurse taps Scan ID Card again if still needed"]
  Error["Reader/read error\nshow status only; retry or use OCR fallback"]
  OcrFallback["OCR fallback path\nmanual exception flow, same private delivery rule"]

  Start --> NurseTap
  NurseTap --> BackendRequest
  BackendRequest --> TurnCode
  TurnCode --> PrivateSub
  TurnCode --> PcDisplay
  PrivateSub --> Compare
  PcDisplay --> Compare
  Compare -->|"Yes"| Insert
  Compare -->|"No"| WaitTurn
  WaitTurn --> Compare
  Insert --> AgentRead
  AgentRead --> BindRead
  BindRead --> KafkaPrivate
  KafkaPrivate --> Autofill
  Autofill --> Done

  Autofill -.->|"if mismatch noticed"| WrongCard
  WrongCard --> Reject
  Reject --> Misrouted
  Misrouted --> Rescan
  Rescan --> NurseTap
  TurnCode -.->|"timeout"| Expired
  Expired --> NurseTap
  AgentRead -.->|"read failed"| Error
  Error -.-> OcrFallback
  OcrFallback -.-> KafkaPrivate

  subgraph SecurityRules["Security rules"]
    NoBroadcast["No full station-wide pending list\nno global broadcast of ID data"]
    SafeStation["Station PC shows code/status only\nno citizen ID, name, address, or photo"]
    PrivateOnly["Full scan payload goes only to\nrequesting nurse/device session"]
    Audit["Audit request, code activation, scan,\ndelivery, reject, expiry"]
  end

  subgraph ClickCount["Expected clicks"]
    Normal["Normal path:\nstation PC: 0 clicks\nnurse iPad: 1 tap to request scan"]
    Exception["Wrong patient / read error:\nextra taps are allowed because it is exception handling"]
    NoSubmit["Avoid extra Submit tap:\nreceiving the private scan result should activate/autofill directly"]
  end

  NoBroadcast --> KafkaPrivate
  SafeStation --> PcDisplay
  PrivateOnly --> PrivateSub
  Audit --> BackendRequest
  Normal --> NurseTap
  Exception --> Reject
  NoSubmit --> Done

  classDef person fill:#e8eef8,stroke:#315f9a,color:#111c2c;
  classDef auto fill:#dff3ea,stroke:#267355,color:#10251c;
  classDef actionStep fill:#fff1d6,stroke:#9b6b16,color:#2b1d05;
  classDef warn fill:#fde7e9,stroke:#a63c49,color:#351014;
  classDef note fill:#f0e8ff,stroke:#7154a6,color:#211438;

  class Start,Insert person;
  class BackendRequest,TurnCode,PrivateSub,PcDisplay,AgentRead,BindRead,KafkaPrivate,Autofill,Done auto;
  class NurseTap,Compare actionStep;
  class WaitTurn,WrongCard,Reject,Misrouted,Rescan,Expired,Error,OcrFallback warn;
  class NoBroadcast,SafeStation,PrivateOnly,Audit,Normal,Exception,NoSubmit note;
